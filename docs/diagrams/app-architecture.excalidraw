    {
      "id": "box3B_label",
      "type": "text",
      "x": 55,
      "y": 1438,
      "width": 300,
      "height": 19,
      "text": "Per-Turn Logic (onUserTurnCompleted)",
      "fontSize": 14,
      "fontFamily": 3,
