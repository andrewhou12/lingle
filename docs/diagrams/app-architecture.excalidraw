    {
      "id": "box4A_label",
      "type": "text",
      "x": 55,
      "y": 1768,
      "width": 500,
      "height": 19,
      "text": "End Endpoint — POST /conversation/end (120s timeout)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
