    {
      "id": "box3A_content",
      "type": "text",
      "x": 55,
      "y": 1182,
      "width": 530,
      "height": 216,
      "text": "Mic → LiveKit (WebRTC) → Silero VAD\n    ↓\nSoniox STT (realtime WS, 24kHz, 1000ms endpoint)\n  INTERIM → UI update only (throttled)\n  PREFLIGHT → preemptive LLM (>500ms + 2+ words)\n  FINAL → triggers onUserTurnCompleted()\n    ↓\nClaude Sonnet (streaming, 200 max tokens)\n  text deltas → TTS immediately (zero buffer)\n  tool calls → fire-and-forget → Redis\n    ↓\nCartesia TTS (persistent WS, reused per session)\n  chunks sent on punctuation or 8+ words\n    ↓\nLiveKit → Speaker + transcription events → UI",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "Mic → LiveKit (WebRTC) → Silero VAD\n    ↓\nSoniox STT (realtime WS, 24kHz, 1000ms endpoint)\n  INTERIM → UI update only (throttled)\n  PREFLIGHT → preemptive LLM (>500ms + 2+ words)\n  FINAL → triggers onUserTurnCompleted()\n    ↓\nClaude Sonnet (streaming, 200 max tokens)\n  text deltas → TTS immediately (zero buffer)\n  tool calls → fire-and-forget → Redis\n    ↓\nCartesia TTS (persistent WS, reused per session)\n  chunks sent on punctuation or 8+ words\n    ↓\nLiveKit → Speaker + transcription events → UI",
      "autoResize": true,
      "lineHeight": 1.35,
      "version": 1,
      "versionNonce": 2025,
      "index": "c5",
