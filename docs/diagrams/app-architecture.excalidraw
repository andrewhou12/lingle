    {
      "id": "t1",
      "type": "text",
      "x": 115,
      "y": 185,
      "width": 272.0,
      "height": 190.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
