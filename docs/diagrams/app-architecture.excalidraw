    {
      "id": "tdc",
      "type": "text",
      "x": 120,
      "y": 2100,
      "width": 971.6,
      "height": 302.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
