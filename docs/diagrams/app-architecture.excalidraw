    {
      "id": "box5B_content",
      "type": "text",
      "x": 695,
      "y": 2402,
      "width": 570,
      "height": 259,
      "text": "Key: session:{sessionId} — TTL 4 hours\n\nSessionState = {\n  sessionId, userId, lessonId\n  lessonPhase: warmup|main|review|wrapup\n  targetLang, nativeLang, lessonGoal\n  difficultyLevel: 1-5\n  errorsLogged: [{type, phrase, correction, rule}]\n  topicsCovered[], vocabIntroduced[]\n  strengthsNoted[], corrections[]\n  memoriesQueued: [{content, memoryType}]\n  elapsedMinutes, lessonDurationTarget (30)\n  avgResponseLatencySec, responseLatencies[10]\n  difficultyConstraints: {\n    grammarStructuresInScope[]\n    maxSentenceComplexity, vocabularyTier\n    allowL1Support: boolean }\n  compactionCount, conversationTokenEstimate\n}\n\nWritten by: Agent tools (during session)\nRead by: Agent per turn + API /end endpoint\nDeleted by: API /end endpoint (cleanup)",
