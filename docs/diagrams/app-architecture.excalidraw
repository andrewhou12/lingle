      "link": null,
      "locked": false,
      "text": "Room Join + Agent Dispatch\n\nGET /api/voice/livekit-token\n  Create pinned LiveKit room\n  Issue AccessToken with grants\n\nPOST /api/voice/start-agent\n  Clean stale dispatches\n  Dispatch agent worker\n  agentMetadata as JSON\n    (sessionId, learnerModel,\n     lessonPlan, userProfile)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "r2",
      "originalText": "Room Join + Agent Dispatch\n\nGET /api/voice/livekit-token\n  Create pinned LiveKit room\n  Issue AccessToken with grants\n\nPOST /api/voice/start-agent\n  Clean stale dispatches\n  Dispatch agent worker\n  agentMetadata as JSON\n    (sessionId, learnerModel,\n     lessonPlan, userProfile)",
      "autoResize": true,
      "lineHeight": 1.25
    },
