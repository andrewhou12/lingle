    {
      "id": "box1B_content",
      "type": "text",
      "x": 805,
      "y": 162,
      "width": 460,
      "height": 405,
      "text": "agentMetadata = {\n  sessionId, userId\n  targetLanguage, nativeLanguage\n  voiceId, languageCode\n  ttsProvider, sttProvider\n\n  learnerModel: {\n    cefrGrammar/Fluency: 1.0-6.0\n    weakAreas: [priorityFocus]\n    sessionsCompleted: N }\n\n  errorPatterns: [\n    { rule, occurrenceCount, sessionCount } ]\n\n  lessonPlan: {\n    warmupTopic, mainActivity\n    targetVocab: string[5]\n    grammarFocus: [displayName]\n    reviewPatterns: string[3] }\n\n  difficultyConstraints: {\n    grammarStructuresInScope: string[15] }\n\n  correctionStyle: recast|explicit|none\n  personalNotes, memories (formatted)\n}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
