    {
      "id": "box3C_content",
      "type": "text",
      "x": 645,
      "y": 1182,
      "width": 330.46875,
      "height": 518.4000000000001,
      "text": "All tools return '' → no speech narration\n\nTRACKING (Pattern A — fire-and-forget → Redis):\n  logError(errorType, phrase, correction, rule)\n    → errorsLogged[]\n    types: grammar|vocabulary|pronunciation\n           |register|l1_interference\n  noteStrength(skill, example)\n    → strengthsNoted[]\n  saveMemory(content, memoryType)\n    → memoriesQueued[]\n    types: personal|preference|goal|context\n  queueCorrection(phrase, correction, rule,\n                   explanation?)\n    → corrections[]\n\nLESSON MGMT (Pattern B — state mutation):\n  adjustDifficulty(direction: up|down, reason)\n    → clamp difficultyLevel 1-5\n  updateLessonPhase(phase)\n    → warmup|main|review|wrapup\n  setVocabHomework(words: string[])\n    → replace vocabIntroduced[]\n  endLesson() → phase = 'wrapup'\n\nONBOARDING ONLY (mode='onboarding'):\n  setGoal(goal, deadline?)\n  calibrateLevel(cefrGrammar, cefrFluency,\n                 rationale)\n  setPreference(key, value)\n    keys: correctionStyle|sessionLength|\n          lessonStylePreference",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
      "isDeleted": false,
      "boundElements": [],
      "link": null,
      "locked": false,
      "containerId": null,
      "originalText": "All tools return '' → no speech narration\n\nTRACKING (Pattern A — fire-and-forget → Redis):\n  logError(errorType, phrase, correction, rule)\n    → errorsLogged[]\n    types: grammar|vocabulary|pronunciation\n           |register|l1_interference\n  noteStrength(skill, example)\n    → strengthsNoted[]\n  saveMemory(content, memoryType)\n    → memoriesQueued[]\n    types: personal|preference|goal|context\n  queueCorrection(phrase, correction, rule,\n                   explanation?)\n    → corrections[]\n\nLESSON MGMT (Pattern B — state mutation):\n  adjustDifficulty(direction: up|down, reason)\n    → clamp difficultyLevel 1-5\n  updateLessonPhase(phase)\n    → warmup|main|review|wrapup\n  setVocabHomework(words: string[])\n    → replace vocabIntroduced[]\n  endLesson() → phase = 'wrapup'\n\nONBOARDING ONLY (mode='onboarding'):\n  setGoal(goal, deadline?)\n  calibrateLevel(cefrGrammar, cefrFluency,\n                 rationale)\n  setPreference(key, value)\n    keys: correctionStyle|sessionLength|\n          lessonStylePreference",
