    {
      "id": "elem_305_8c365f51",
      "type": "text",
      "x": 72,
      "y": 5538,
      "width": 550.88,
      "height": 337.45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
