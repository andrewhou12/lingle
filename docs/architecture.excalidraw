        "elem_208_2df3d087"
      ],
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772141272275,
      "link": null,
      "locked": false,
      "text": "Assessment candidates sourced from reference corpus\ngetAssessmentCandidates(jlptLevel?) -> curated items by level\ngetLevelCefrMapping() -> JLPT<->CEFR map\n\nThree-tier seeding strategy:\n  Below level -> introduced (known = apprentice_2)\n  At level    -> unseen (known = apprentice_2)\n  Above level -> NOT seeded (curriculum engine introduces)\nWipes stale CurriculumItem queue on complete",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Assessment candidates sourced from reference corpus\ngetAssessmentCandidates(jlptLevel?) -> curated items by level\ngetLevelCefrMapping() -> JLPT<->CEFR map\n\nThree-tier seeding strategy:\n  Below level -> introduced (known = apprentice_2)\n  At level    -> unseen (known = apprentice_2)\n  Above level -> NOT seeded (curriculum engine introduces)\nWipes stale CurriculumItem queue on complete",
      "autoResize": true,
      "lineHeight": 1.35
    },
