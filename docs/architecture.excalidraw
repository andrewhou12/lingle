      "locked": false,
      "text": "Flow E: Curriculum Recommendation Pipeline (Spine-Aware)",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow E: Curriculum Recommendation Pipeline (Spine-Aware)",
      "autoResize": true,
