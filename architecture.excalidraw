    {
      "id": "elem_205_1106143e",
      "type": "text",
      "x": 812,
      "y": 3398,
      "width": 513.18,
      "height": 512.95,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
