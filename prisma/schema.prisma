generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Core User ──────────────────────────────────────────────────────────────

model User {
  id                    String   @id // Supabase auth user ID
  email                 String?
  name                  String?
  avatarUrl             String?  @map("avatar_url")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Program configuration (set during onboarding)
  targetLanguage        String?  @map("target_language")
  nativeLanguage        String?  @map("native_language")
  sessionLengthMinutes  Int      @default(30) @map("session_length_minutes")
  onboardingComplete    Boolean  @default(false) @map("onboarding_complete")

  // User profile fields (spec Section 1.1)
  interests             String[] @default([])
  occupation            String?
  family                String?
  goals                 String?
  recentUpdates         String[] @default([]) @map("recent_updates") // rolling, capped at 10

  // Pedagogical preferences
  correctionStyle       String   @default("recast") @map("correction_style")

  // Session stats
  totalLessons          Int      @default(0) @map("total_lessons")
  totalMinutes          Int      @default(0) @map("total_minutes")

  // Voice pipeline preferences (optional overrides — null = use defaults)
  ttsProvider           String?  @map("tts_provider")
  sttProvider           String?  @map("stt_provider")
  voiceId               String?  @map("voice_id")

  // Relations
  learnerModel    LearnerModel?
  lessons         Lesson[]
  errorLogs       ErrorLog[]
  introducedItems IntroducedItem[]
  subscription    Subscription?
  dailyUsage      DailyUsage[]

  @@map("users")
}

// ─── Learner Model ──────────────────────────────────────────────────────────

model LearnerModel {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id")
  updatedAt DateTime @updatedAt @map("updated_at")

  // CEFR sub-scores — decimal 1.0–6.0
  cefrGrammar Float @default(1.0) @map("cefr_grammar")
  cefrFluency Float @default(1.0) @map("cefr_fluency")

  // Skills — stored as JSON array of SkillRecord
  skills Json @default("[]")

  // Session metadata
  sessionCount  Int @default(0) @map("session_count")
  totalMinutes  Int @default(0) @map("total_minutes")
  lastSessionDate DateTime? @map("last_session_date")

  // Relations
  user          User           @relation(fields: [userId], references: [id])
  producedItems ProducedItem[]

  @@map("learner_models")
}

// ─── Produced Items (vocab/grammar the learner has used in speech) ───────────

model ProducedItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  learnerModelId  String   @map("learner_model_id") @db.Uuid
  userId          String   @map("user_id")
  type            String   // vocab | grammar
  surface         String   // the word or grammar pattern
  targetLanguage  String   @map("target_language")
  occurrenceCount Int      @default(1) @map("occurrence_count")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")

  learnerModel LearnerModel @relation(fields: [learnerModelId], references: [id])

  @@unique([userId, type, surface])
  @@index([userId])
  @@index([learnerModelId])
  @@map("produced_items")
}

// ─── Curriculum Reference Lists (deterministic, seeded, no state) ────────────
// These are lookup tables only — no mastery tracking, no SRS.
// Used to constrain LLM extraction in the pipeline and to pick targets in planning.

model CurriculumVocab {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  language    String  // ISO 639-1: ja, es, fr, etc.
  surface     String  // the word in target language
  reading     String? // pronunciation guide (furigana, pinyin, etc.)
  translation String  // English translation
  cefrLevel   String  @map("cefr_level") // A1 | A2 | B1 | B2 | C1 | C2
  domain      String? // food | travel | work | health | relationships | hobbies | etc.

  @@unique([language, surface])
  @@index([language, cefrLevel])
  @@index([language, domain])
  @@map("curriculum_vocab")
}

model CurriculumGrammar {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  language    String // ISO 639-1
  pattern     String // machine-readable key: te_form, passive, conditional_tara
  displayName String @map("display_name") // human-readable: て-form, passive voice
  cefrLevel   String @map("cefr_level")
  description String // brief explanation of the pattern

  @@unique([language, pattern])
  @@index([language, cefrLevel])
  @@map("curriculum_grammar")
}

// ─── Introduced Items (pedagogically surfaced, not incidental) ──────────────

model IntroducedItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id")
  sessionId    String   @map("session_id") @db.Uuid
  type         String   // vocab | grammar | phrase
  surface      String   // the word, pattern, or phrase
  translation  String?
  notes        String?
  introducedAt DateTime @default(now()) @map("introduced_at")

  user    User   @relation(fields: [userId], references: [id])
  session Lesson @relation(fields: [sessionId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@map("introduced_items")
}

// ─── Lessons (Session Records) ──────────────────────────────────────────────

model Lesson {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int?      @map("duration_minutes")
  targetLanguage  String    @map("target_language")

  // Pre-session planning output (stored verbatim as JSON)
  lessonPlan Json? @map("lesson_plan")

  // Post-session outputs
  transcript      Json?     // TranscriptTurn[]
  correctionsDoc  String?   @map("corrections_doc")
  sessionSummary  Json?     @map("session_summary") // SessionSummary

  // Pipeline state (for resumability)
  pipelineStage       String?   @map("pipeline_stage") // PipelineStage
  pipelineCompletedAt DateTime? @map("pipeline_completed_at")

  // Relations
  user            User             @relation(fields: [userId], references: [id])
  errorLogs       ErrorLog[]
  introducedItems IntroducedItem[]

  @@index([userId])
  @@map("lessons")
}

// ─── Error Logs (per-error, per-session, session-scoped only) ───────────────

model ErrorLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id")
  lessonId        String   @map("lesson_id") @db.Uuid
  loggedAt        DateTime @default(now()) @map("logged_at")

  utteranceIndex  Int      @map("utterance_index")
  userUtterance   String   @map("user_utterance")
  errorType       String   @map("error_type")  // grammar | vocab | pronunciation | register | l1_interference
  errorDetail     String   @map("error_detail")
  correction      String
  severity        String   // pedantic | minor | major
  likelySttArtifact Boolean @default(false) @map("likely_stt_artifact")

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@index([userId])
  @@index([lessonId])
  @@map("error_logs")
}

// ─── Billing ────────────────────────────────────────────────────────────────

model Subscription {
  id                   Int       @id @default(autoincrement())
  userId               String    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id])
  plan                 String    @default("free") // "free" | "pro"
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  status               String    @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model DailyUsage {
  id                  Int      @id @default(autoincrement())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  date                DateTime @db.Date
  conversationSeconds Int      @default(0) @map("conversation_seconds")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_usage")
}
